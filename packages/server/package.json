{
  "name": "@relayauth/server",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    },
    "./durable-objects": {
      "types": "./dist/durable-objects/index.d.ts",
      "import": "./dist/durable-objects/index.js"
    }
  },
  "dependencies": {
    "hono": "^4",
    "@relayauth/sdk": "0.1.0",
    "@relayauth/types": "0.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "wrangler": "^4"
  },
  "scripts": {
    "dev": "wrangler dev --config ../../wrangler.toml --local --persist-to ../../.wrangler/state --ip 127.0.0.1 --port 8787",
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx src/__tests__/*.test.ts src/__tests__/e2e/*.test.ts"
  }
}
