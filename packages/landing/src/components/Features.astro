---
type Accent = "cyan" | "emerald" | "amber" | "sky";

const features: Array<{ name: string; accent: Accent; body: string }> = [
  {
    name: "Scoped tokens",
    accent: "cyan",
    body: "Issue short-lived JWTs with plane:resource:action:path scopes. Least-privilege by default — agents only get the access they need."
  },
  {
    name: "Sponsor chain",
    accent: "emerald",
    body: "Every agent traces back to a human. The human → agent → sub-agent chain stays intact through delegation, audits, and incident response."
  },
  {
    name: "Instant revocation",
    accent: "amber",
    body: "One call, global, under a second. Revoke once and every Relay plane sees it — no waiting for long-lived secrets to age out."
  },
  {
    name: "Behavioral budgets",
    accent: "sky",
    body: "Rate limits, spending caps, and auto-suspend at threshold. Set guardrails before the agent starts and enforce them at the edge."
  }
];

const accentClasses = {
  cyan: "border-cyan-400/20 bg-cyan-400/10 text-cyan-200",
  emerald: "border-emerald-400/20 bg-emerald-400/10 text-emerald-200",
  amber: "border-amber-300/20 bg-amber-300/10 text-amber-100",
  sky: "border-sky-400/20 bg-sky-400/10 text-sky-200"
};
---

<section id="features" class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-medium uppercase tracking-[0.28em] text-cyan-200/80">Features</p>
    <h2 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl">Purpose-built auth for delegated systems</h2>
    <p class="mt-4 text-lg leading-8 text-slate-300">
      Agents do not fit human auth patterns. relayauth gives you least-privilege access, durable attribution, and enough control to stop a bad run before it spreads.
    </p>
  </div>

  <div class="mt-12 grid gap-6 md:grid-cols-2">
    {
      features.map((feature, index) => (
        <article class="rounded-3xl border border-white/10 bg-white/5 p-7 backdrop-blur">
          <div class={`inline-flex h-11 w-11 items-center justify-center rounded-2xl border ${accentClasses[feature.accent]}`}>
            <span class="text-sm font-semibold">0{index + 1}</span>
          </div>
          <h3 class="mt-5 text-2xl font-semibold text-white">{feature.name}</h3>
          <p class="mt-3 text-base leading-7 text-slate-300">{feature.body}</p>
        </article>
      ))
    }
  </div>
</section>
