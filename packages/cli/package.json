{
  "name": "relayauth",
  "version": "0.1.8",
  "description": "CLI for relayauth",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "relayauth": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test --import tsx src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@relayauth/sdk": "*",
    "@relayauth/types": "*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayauth",
    "directory": "packages/cli"
  }
}
