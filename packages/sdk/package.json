{
  "name": "@relayauth/sdk",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "node --test --import tsx $(find src/__tests__ -maxdepth 1 -name '*.test.ts' ! -name 'verify.test.ts' -print | sort) && vitest run --config vitest.config.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@relayauth/types": "*",
    "hono": "^4"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
